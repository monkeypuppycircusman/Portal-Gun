# CORE CONSTANTS AND FUNCTIONS

# Riemann zeta gates (numerical constants)
ZETA_EVEN   = ζ(2)      ≈ 1.64493406685      # build / collapse pole
ZETA_ODD_FR = ζ(2/3)*ζ(3) ≈ -2.943…         # prune / invert (odd branches)
# Golden ratio and prune reset
PHI        = (1 + √5)/2           ≈ 1.61803398875
PRUNE_RESET = 1 / PHI^2           ≈ 0.38196601125
# Metallic ratio for dimension k (k = 1: golden, 2: silver, 3: bronze, 4: copper, 5: nickel, 6: zinc, …)
# δ_k = (k + √(k² + 4)) / 2
metallic(k) = (k + sqrt(k^2 + 4)) / 2
# Shear function (optional bandwidth/helical modulation)
# Example base: golden-skewed sinusoid
shear_base(n) = n * sin(π * n / PHI)
# GENERAL PORTAL RATIO LAW (SCALABLE IN DIMENSION)

# For dimension index k (effective D-dim portal: k=2→2D, 3→3D, 4→4D, 5→5D, 6→6D, …)
# and branch level n (1,2,3,…), define the base energy-per-dimension ratio:
#   R_base(k, n) = δ_k / (k * n)
# where δ_k = metallic(k).

R_base(k, n) = metallic(k) / (k * n)
# OPTIONAL: include shear modulation (bandwidth / twist)
#   R_base_sheared(k, n) = R_base(k, n) * shear_base(n)
R_base_sheared(k, n) = R_base(k, n) * shear_base(n)
# ZETA GATING (OPEN/CLOSE + PUSH/PULL)

# Gate rule (without shear; swap R_base_sheared if using shear):
#   if n is even: R_gate = R_base * ZETA_EVEN      (build / collapse)
#   if n is odd:  R_gate = R_base * ZETA_ODD_FR    (prune / invert)

R_gate(k, n) =
    if n % 2 == 0:
        R_base(k, n) * ZETA_EVEN
    else:
        R_base(k, n) * ZETA_ODD_FR
# PRUNE MECHANIC

# If |R_gate| exceeds a chaos threshold (e.g. 13), reset to 1/φ²:
#   R_pruned = sign(R_gate) * PRUNE_RESET  (or just PRUNE_RESET if you want full neutral reset)
# Else:
#   R_pruned = R_gate

CHAOS_THRESHOLD = 13.0
R_pruned(k, n) =
    if abs(R_gate(k, n)) > CHAOS_THRESHOLD:
        sign(R_gate(k, n)) * PRUNE_RESET
    else:
        R_gate(k, n)
# ENERGY AND PORTAL STATE

# Let D_eff be the effective dimensional size (can set D_eff = 1 for normalized sims).
# Then:
#   E = R_pruned * D_eff
# Portal is OPEN if |R_pruned| > τ_open, CLOSED otherwise.
# Typical τ_open ≈ 0.5 (tunable).

E(k, n, D_eff) = R_pruned(k, n) * D_eff
τ_open = 0.5
portal_state(k, n, D_eff) =
    if abs(R_pruned(k, n)) > τ_open:
        "OPEN"
    else:
        "CLOSED"
