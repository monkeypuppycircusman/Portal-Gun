#include <math.h>

#define PHI ((1.0 + sqrt(5.0)) / 2.0)
#define HAPTIC_PIN 5     // GPIO for piezo/vibrator
#define LED_PIN 4        // RGB LED (or simple one)
#define TICK_INTERVAL 2000  // ms between n advances (~every 2s)

float n = 1.0;
float tau = 12.0;

void setup() {
  pinMode(HAPTIC_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  analogWrite(HAPTIC_PIN, 0);
  digitalWrite(LED_PIN, LOW);
}

void loop() {
  float phase = 2.0 * M_PI * n / PHI;  // or M_PI for slower
  float amp = sin(phase) * exp(-n / tau);

  if (fabs(amp) > 0.6) {
    int intensity = map(fabs(amp), 0.6, 1.0, 80, 255);
    analogWrite(HAPTIC_PIN, intensity);     // haptic pulse
    digitalWrite(LED_PIN, HIGH);            // glow
    delay(150);                             // short burst
    analogWrite(HAPTIC_PIN, 0);
    digitalWrite(LED_PIN, LOW);
  }

  delay(TICK_INTERVAL);
  n += 0.1;  // slow advance
  if (n > 50) n = 1.0;  // loop
}
